{
    "version": 2,
    "builds": [
        {
            "src": "code/frontend/package.json",
            "use": "@vercel/vite"
        },
        {
            "src": "code/backend/src/app.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "code/backend/src/app.ts"
        },
        {
            "src": "/(.*)",
            "dest": "code/frontend/dist/$1"
        }
    ]
}